// Project-local debug tasks
//
// For more documentation on how to configure debug tasks,
// see: https://zed.dev/docs/debugger
[
  {
    "label": "debug test",
    "build": {
      "command": "zig",
      "args": [
        "test",
        "--test-no-exec",
        "-ODebug",
        "-femit-bin=test-bin",
        "main.zig",
      ],
      "cwd": "$ZED_WORKTREE_ROOT",
    },
    "program": "$ZED_WORKTREE_ROOT/test-bin",
    "request": "launch",
    "adapter": "CodeLLDB",
  },
  {
    "label": "debug",
    "build": {
      "command": "zig",
      "args": [
        "build",
      ],
      "cwd": "$ZED_WORKTREE_ROOT",
    },
    "program": "$ZED_WORKTREE_ROOT/zig-out/bin/zig_sdl3_test",
    "request": "launch",
    "adapter": "CodeLLDB",
  },
]
